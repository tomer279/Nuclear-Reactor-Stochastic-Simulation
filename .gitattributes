# Auto detect text files and perform LF normalization
* text=auto
*.npy filter=lfs diff=lfs merge=lfs -text

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Configuration files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Data files (if you want to track small data files)
*.csv text eol=lf
*.tsv text eol=lf

# Binary files (should not be modified)
*.npy binary
*.npz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Jupyter notebooks
*.ipynb text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf