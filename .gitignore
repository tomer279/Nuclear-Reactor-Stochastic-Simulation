# =============================================================================
# PROJECT SPECIFIC
# =============================================================================

# Large data files (handled by Git LFS)
# Note: .npy files are tracked by Git LFS, so we don't ignore them here

# Output and temporary files
outputs/
temp/
tmp/
*.tmp
*.temp

# Plot and image files (unless you want to keep them)
plots/
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.svg
*.pdf
*.eps

# Log files
*.log
logs/
log/

# Backup files
*.bak
*.backup
*~

# Configuration files with sensitive data
config_local.py
secrets.py
.env.local

# Data files that shouldn't be version controlled
# (Keep example data, ignore large datasets)
data/raw/
data/temp/
data/backup/

# Keep example data
!data/example/
!*.npy.example
!data/example/**/*.npy

